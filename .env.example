# https://developer.riotgames.com 에서 발급 (개발 키는 24시간마다 만료)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Production API Key(승인제)를 받으면 prod로 변경 — 레이트리밋이 풀려 정밀 분석이 수 초 만에 끝남
RIOT_KEY_TYPE=dev

# 선택: Supabase Postgres 연결 문자열. 비워두면 인메모리 캐시로 동작
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# 선택: 디스코드 승급/강등 알림 웹훅 (서버 설정 → 연동 → 웹훅에서 생성)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 새벽 자동 갱신 크론 인증용 (Vercel 환경변수에도 동일하게 등록)
# CRON_SECRET=
